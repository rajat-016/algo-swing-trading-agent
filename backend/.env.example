# Algo Swing Trading Agent - Configuration

# Trading Parameters
TARGET_PROFIT_PCT=10.0
STOP_LOSS_PCT=3.0
MAX_POSITIONS=10
RISK_PER_TRADE=1.0
MIN_CONFIDENCE=70.0
CYCLE_INTERVAL_SECONDS=300

# Database
DATABASE_URL=sqlite:///trading.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Trading Mode (paper/live)
TRADING_MODE=paper

# Auto-start trading loop on server startup (true/false)
AUTO_START_TRADING=false

# Paper Trading Capital (for simulation)
PAPER_TRADING_CAPITAL=100000

# ChartInk Screener URL
CHARTINK_URL=https://chartink.com/screener/swing-2026-04-10-2

# Zerodha API Credentials
# Get from: https://developers.kite.trade/
ZERODHA__API_KEY=your_api_key
ZERODHA__API_SECRET=your_api_secret
ZERODHA__ACCESS_TOKEN=your_access_token
ZERODHA__REQUEST_TOKEN=

# Options: cta (paper/simulation) or prod (live trading)
ZERODHA__ENVIRO=prod

# AI Copilot Settings
AI_COPILOT_ENABLED=true
OLLAMA_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_CONCURRENCY=4
EMBEDDING_CACHE_MAX_SIZE=10000
EMBEDDING_CACHE_TTL_SECONDS=86400
EMBEDDING_CACHE_PERSIST_PATH=data/embedding_cache
EMBEDDING_RETRY_MAX_RETRIES=3
EMBEDDING_RETRY_BASE_DELAY=1.0
EMBEDDING_RETRY_MAX_DELAY=30.0
CHROMADB_PERSIST_PATH=data/chromadb
DUCKDB_PATH=data/analytics.duckdb