# Algo Swing Trading Agent - Configuration

# Trading Parameters
TARGET_PROFIT_PCT=10.0
STOP_LOSS_PCT=3.0
MAX_POSITIONS=10
RISK_PER_TRADE=1.0
MIN_CONFIDENCE=70.0

# Database
DATABASE_URL=sqlite:///trading.db

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Trading Mode (paper/live)
TRADING_MODE=paper

# Paper Trading Capital (for simulation)
PAPER_TRADING_CAPITAL=100000

# ChartInk Screener URL
CHARTINK_URL=https://chartink.com/screener/swing-2026-04-10-2

# Zerodha API Credentials
# Get from: https://developers.kite.trade/
ZERODHA__API_KEY=your_api_key
ZERODHA__API_SECRET=your_api_secret
ZERODHA__ACCESS_TOKEN=your_access_token
ZERODHA__REQUEST_TOKEN=

# Options: cta (paper/simulation) or prod (live trading)
ZERODHA__ENVIRO=prod